#!/bin/sh
# Versioned pre-push gate (enabled via: git config core.hooksPath .githooks).
# Two responsibilities:
#   1. Block direct push to master (master is PR-merge-only).
#   2. Run bin/prepush-review (deterministic supply-chain checks) on the
#      branch being pushed. This replaces the retired claude-review.yml
#      GitHub Action; judgment review is still done by a human during PR
#      processing.
# Emergency override for both: git push --no-verify

remote="$1"
protected_branch="refs/heads/master"
zero=$(git hash-object --stdin </dev/null | tr '0-9a-f' '0')
repo_root=$(git rev-parse --show-toplevel)

status=0
while read -r local_ref local_oid remote_ref remote_oid; do
    # 1. master protection
    if [ "$remote_ref" = "$protected_branch" ]; then
        if [ "$local_oid" = "$zero" ]; then
            echo "pre-push: refusing to DELETE $protected_branch on $remote" >&2
        else
            echo "pre-push: refusing direct push to $protected_branch on $remote" >&2
            echo "pre-push: open a PR and merge it on GitHub instead." >&2
            echo "pre-push: (emergency override: git push --no-verify)" >&2
        fi
        exit 1
    fi

    # skip branch deletions
    [ "$local_oid" = "$zero" ] && continue

    # 2. deterministic supply-chain review of the pushed commits
    if [ "$remote_oid" = "$zero" ]; then
        base="origin/master"   # new branch: review the whole branch vs master
    else
        base="$remote_oid"     # existing branch: review only the new commits
    fi
    if ! "$repo_root/bin/prepush-review" "$base" "$local_oid"; then
        status=1
    fi
done

exit $status
