{
	# tailnet 内向けなので既定は素の HTTP。 TLS を張るなら auto_https を
	# 有効化し、 site address を `nekono-dist0.<tailnet>.ts.net` にして
	# Tailscale の cert 機能を使う。
	admin off
	auto_https off
}

# :80 で配信。 本番は compose 側で Tailscale IP に bind する
# (0.0.0.0 に晒さない。 詳細は deploy/dist/README.md)。
:80 {
	root * /srv/repo

	# --- 書き込み系 (publish の rclone WebDAV) は basic_auth 必須 ---
	# pacman は GET/HEAD しか投げないので、 これらの method は publish 専用。
	@dav method PUT DELETE MKCOL COPY MOVE PROPFIND PROPPATCH LOCK UNLOCK
	handle @dav {
		basic_auth {
			{$DAV_USER} {$DAV_HASH}
		}
		webdav
	}

	# --- それ以外 (pacman の GET/HEAD) は匿名 static 配信 ---
	# 署名は artifact に付随するので配信は土管でよい (信頼モデル参照)。
	handle {
		file_server {
			hide .env* .git*
		}
	}

	log {
		output stdout
		format console
	}
}
