# Caddy = 匿名 GET 専用 (pacman 向け)。 書き込み (publish) は別 service の
# dufs (:8080) が担うので、 ここでは静的配信だけ。 volume は compose 側で
# read-only mount されている。
{
	admin off
	auto_https off        # tailnet 内 HTTP。 TLS を張るなら site address を
	                      # `nekono-dist0.<tailnet>.ts.net` にして Tailscale cert を使う。
}

:80 {
	root * /srv/repo

	file_server {
		browse            # ブラウザ閲覧用 index (pacman GET には不要だが便利)
	}

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
	}

	log {
		output stdout     # docker logs に出す (file 出力は volume 無しだと消えるため)
		format console
	}
}
