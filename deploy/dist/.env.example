# cp .env.example .env し、値を埋める。 .env は .gitignore 済み、 commit しない。
#
# WebDAV publish 用の認証情報。 build host 側の bin/publish が
# 同じ user/平文 pass を使う (下記 DAV_HASH の元の平文)。

DAV_USER=nekono-publish

# bcrypt hash を生成して貼る (平文は commit しない):
#   docker run --rm caddy:2 caddy hash-password --plaintext 'YOUR_STRONG_PASS'
DAV_HASH=REPLACE_WITH_BCRYPT_HASH
