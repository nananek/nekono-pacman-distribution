# cp .env.example .env し、値を埋める。 .env は .gitignore 済み、 commit しない。

# tailscale sidecar が tailnet に join するための auth key (初回のみ必要)。
# https://login.tailscale.com/admin/settings/keys で発行して貼る。
TS_AUTHKEY=

# dufs (publish WebDAV, :8080) の認証。 dufs は bcrypt ではなく **平文** の
# user:pass を取る。 build host の bin/publish が同じ値を
# NEKONO_DAV_USER / NEKONO_DAV_PASS で使う。
DUFS_USER=nekono-publish
DUFS_PASS=REPLACE_WITH_STRONG_PASSWORD
