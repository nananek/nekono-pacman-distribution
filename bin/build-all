#!/usr/bin/env bash
# build-all: pkgs/* の PKGBUILD を順番に makepkg + gpg --detach-sign +
# repo-add する pipeline。
#
# build 順は **[nekono] 内部 cross-dep の topological sort** (= dep が先、
# 依存先が後)。 alphabetical ではないので、 例えば python-fastmcp は
# python-mcp の後ろに来る。
#
# --pending mode では「自 pkg の pkgver-pkgrel に対応する artifact が
# 無い pkg」 だけを build する。 加えて、 build される pkg を [nekono]
# cross-dep に持つ下流 pkg について **cascade-warn** を出力する (= 「dep が
# 今 rebuild されたので pkgrel +1 PR を立てるべし」 という人間向け警告、
# auto-rebuild はしない方針 = 1 PKGBUILD = 1 PR = GPG 署名規約を守るため)。
#
# 前提:
#   - Arch build host で実行
#   - YubiKey (Nekono GPG) が NFC リーダー上に乗ってる、gpg-agent / scdaemon
#     経路が生きてる (= gpg --card-status で OpenPGP card が見える)
#   - PIN cache が build 全体を覆える長さで効いてる (gpg-agent.conf の
#     default-cache-ttl は 3600+ 推奨。最初の sign で 1 度入力)
#   - repo-add の base path = repo/x86_64/ (.gitignore で git 管理外)
#   - tsort (coreutils) が PATH 上にある
#
# 使い方:
#   bin/build-all                 # 全 pkgs を topo 順で build + sign + db に追加
#   bin/build-all vesktop-bin     # 個別指定 (1 つだけ build)
#   bin/build-all --pending       # PKGBUILD の pkgver-pkgrel に対応する
#                                 # repo/x86_64/<name>-<full-ver>-*.pkg.tar.zst
#                                 # が存在しない pkg だけを topo 順で build
#                                 # (= デイリー運用: git pull --ff-only &&
#                                 # bin/build-all --pending)
#   bin/build-all --dry-run       # build せず計画 + cascade-warn だけ表示
#                                 # (--pending と組み合わせ可)
#
# Exit code:
#   0 = 全部成功 (--pending 時、未 build が 0 件でも 0)
#   1 = 1 つでも fail (途中で止まる、--keep-going 派生は将来必要なら検討)

set -euo pipefail

NEKONO_GPG_FP="483DC691DF9F29327EA106BD030130E2F156CD74"
REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
REPO_DIR="$REPO_ROOT/repo/x86_64"
DB_NAME="nekono"

mkdir -p "$REPO_DIR"

# 引数 parse: --pending / --dry-run を吸って、残りは pos args (= 個別 pkg 指定)。
PENDING_ONLY=false
DRY_RUN=false
while [[ $# -gt 0 ]]; do
    case "$1" in
        --pending)
            PENDING_ONLY=true
            shift
            ;;
        --dry-run)
            DRY_RUN=true
            shift
            ;;
        --)
            shift
            break
            ;;
        -*)
            echo "[ERROR] unknown option: $1" >&2
            exit 1
            ;;
        *)
            break
            ;;
    esac
done

# pos args = 個別 package 指定、なければ pkgs/* 全て。
if [[ $# -gt 0 ]]; then
    requested=("$@")
else
    requested=()
    for d in "$REPO_ROOT"/pkgs/*/; do
        requested+=("$(basename "$d")")
    done
fi

if [[ ${#requested[@]} -eq 0 ]]; then
    echo "[ERROR] no packages found under $REPO_ROOT/pkgs/" >&2
    exit 1
fi

# [nekono] pkg universe = pkgs/*/ 配下で PKGBUILD を持つ全 dir。 cross-dep
# graph を構築するために、 requested 以外も含めて全件 enumerate する必要が
# ある (= 例えば user が 'build-all python-fastmcp' と指定しても、 cross-dep
# 計算には python-mcp 等が必要)。
nekono_universe=()
for d in "$REPO_ROOT"/pkgs/*/; do
    p=$(basename "$d")
    if [[ -f "$d/PKGBUILD" ]]; then
        nekono_universe+=("$p")
    fi
done

# 各 pkg の [nekono] cross-dep を .SRCINFO から抽出 (depends + makedepends)。
# version 制約 (>=, <, =) は strip して plain pkgname にしてから universe と
# 照合する。
declare -A nekono_cross_deps
for p in "${nekono_universe[@]}"; do
    srcinfo="$REPO_ROOT/pkgs/$p/.SRCINFO"
    if [[ ! -f "$srcinfo" ]]; then
        nekono_cross_deps[$p]=""
        continue
    fi
    cross=""
    while IFS= read -r dep; do
        [[ -z "$dep" ]] && continue
        for np in "${nekono_universe[@]}"; do
            if [[ "$np" == "$dep" ]]; then
                cross+="$dep "
                break
            fi
        done
    done < <(awk '
        /^[[:space:]]*(depends|makedepends) = /{
            sub(/^[[:space:]]*(depends|makedepends) = /, "")
            sub(/[<>=].*$/, "")
            print
        }
    ' "$srcinfo" | sort -u)
    nekono_cross_deps[$p]="${cross% }"
done

# tsort で全 universe を topo 順に並べる。 __root__ という phantom node を
# 全 pkg の前に置くことで、 cross-dep を 1 つも持たない pkg も output に
# 含まれるようにする (= tsort は edge を持たない node を print しない仕様)。
tsort_input=""
for p in "${nekono_universe[@]}"; do
    tsort_input+="__root__ $p"$'\n'
    for dep in ${nekono_cross_deps[$p]}; do
        tsort_input+="$dep $p"$'\n'
    done
done
mapfile -t topo_all < <(printf '%s' "$tsort_input" | tsort 2>/dev/null | grep -v '^__root__$')

# 要 build の pkg を requested から topo 順に並べ替え。
topo_ordered=()
for p in "${topo_all[@]}"; do
    for r in "${requested[@]}"; do
        if [[ "$p" == "$r" ]]; then
            topo_ordered+=("$p")
            break
        fi
    done
done

# requested に入っていたが universe に居なかった pkg (= PKGBUILD 不在) は
# WARN を出して final list には入れない。
for r in "${requested[@]}"; do
    found=false
    for p in "${topo_ordered[@]}"; do
        if [[ "$p" == "$r" ]]; then
            found=true
            break
        fi
    done
    if ! $found; then
        echo "[WARN] skip $r (no PKGBUILD or not in topo)" >&2
    fi
done

# PKGBUILD から pkgver / pkgrel / epoch を抽出して full_ver を作る関数。
# bash 変数展開 (= '${_commit::7}' '${_upstreamver}' 等) を解決するため、
# subshell で PKGBUILD を source する。 PKGBUILD は convention 上 toplevel
# 代入 + 関数定義のみ (= build() / package() は呼ばれない) なので副作用なし。
extract_full_ver() {
    local pkgbuild="$1"
    (
        unset pkgver pkgrel epoch
        # shellcheck disable=SC1090
        source "$pkgbuild" 2>/dev/null || true
        if [[ -n "${epoch:-}" ]]; then
            echo "${epoch}:${pkgver}-${pkgrel}"
        else
            echo "${pkgver}-${pkgrel}"
        fi
    )
}

# 各 pkg の full_ver と「artifact が repo/x86_64/ に存在するか」 を計算。
# universe 全体について計算する (= cascade 検出は universe scope)。
declare -A pkg_full_ver
declare -A initial_pending
for p in "${nekono_universe[@]}"; do
    pkgbuild="$REPO_ROOT/pkgs/$p/PKGBUILD"
    full_ver=$(extract_full_ver "$pkgbuild")
    pkg_full_ver[$p]="$full_ver"
    if compgen -G "$REPO_DIR/${p}-${full_ver}-"'*'".pkg.tar.zst" >/dev/null; then
        initial_pending[$p]=false
    else
        initial_pending[$p]=true
    fi
done

# cascade-warn 計算: topo 順に走査し、 自 pkg の [nekono] cross-dep の中で
# 「initial_pending == true (= 今 rebuild される) もしくは cascade_warn 済み
# (= 上流が rebuild されたので本来 rebuild すべき)」 が 1 つでもあれば warn。
# transitive 対応のため topo 順走査 + 既 mark を伝播する設計。
# 自 pkg 自体が initial_pending の場合は warn 不要 (= どの道 build される)。
declare -A cascade_deps
for p in "${topo_all[@]}"; do
    cascade_deps[$p]=""
    ${initial_pending[$p]:-false} && continue
    for dep in ${nekono_cross_deps[$p]}; do
        if [[ "${initial_pending[$dep]:-false}" == "true" ]] || [[ -n "${cascade_deps[$dep]:-}" ]]; then
            cascade_deps[$p]+="$dep "
        fi
    done
done

# Build target list を決定。 --pending: initial_pending のみ topo 順で。
if $PENDING_ONLY; then
    packages=()
    for p in "${topo_ordered[@]}"; do
        if ${initial_pending[$p]}; then
            packages+=("$p")
            echo "[pending] $p ${pkg_full_ver[$p]}"
        else
            echo "[skip] $p ${pkg_full_ver[$p]} already built"
        fi
    done
else
    packages=("${topo_ordered[@]}")
fi

# cascade-warn を出力 (= build target に居ない / build されない pkg のうち、
# [nekono] dep が今 rebuild されるもの)。 universe scope で見るので、
# 'build-all foo' で foo の dep が触られない場合は何も出ない。
cascade_pkgs=()
for p in "${topo_all[@]}"; do
    if [[ -n "${cascade_deps[$p]}" ]] && ! ${initial_pending[$p]:-false}; then
        cascade_pkgs+=("$p")
        echo "[cascade-warn] $p ${pkg_full_ver[$p]} should bump pkgrel via PR (= [nekono] dep ${cascade_deps[$p]% } was rebuilt in this run)"
    fi
done

# Detect retired packages: db に entry はあるが pkgs/ 側に対応する PKGBUILD が
# 既に削除されているもの (= ローカルで `git rm -r pkgs/<name>/` した結果)。
# repo-add は addition 専用なので、 別途 repo-remove + bin/prune で db + file
# 両方を掃除する必要がある。 retirement は build target (`requested`) や
# `--pending` フラグとは独立に常に検査・実行する (= 1 度 push されれば
# 次の build-all 実行で必ず反映される)。
#
# 対応付けは dir 名 (= pkgbase) だけでなく pkgs/*/.SRCINFO の pkgname 行
# 全部を生存集合にする (= split package 対応。 bluez の db entry は
# bluez-libs / bluez-utils 等で dir 名と一致しない)。 makepkg が自動生成
# する <pkgbase>-debug も db に入るので生存扱いにする。
retired_pkgs=()
db_file="$REPO_DIR/$DB_NAME.db.tar.gz"
if [[ -f "$db_file" ]]; then
    declare -A live_pkg_names=()
    for d in "$REPO_ROOT"/pkgs/*/; do
        [[ -f "$d/PKGBUILD" ]] || continue
        _base="$(basename "$d")"
        live_pkg_names["$_base"]=1
        live_pkg_names["$_base-debug"]=1
        if [[ -f "$d/.SRCINFO" ]]; then
            while IFS= read -r _n; do
                live_pkg_names["$_n"]=1
            done < <(awk '$1 == "pkgname" { print $3 }' "$d/.SRCINFO")
        fi
    done
    mapfile -t db_listed_names < <(
        tar -xzO -f "$db_file" --wildcards '*/desc' 2>/dev/null \
            | awk '/^%NAME%$/{getline n; print n}'
    )
    for n in "${db_listed_names[@]}"; do
        [[ -n "${live_pkg_names[$n]:-}" ]] || retired_pkgs+=("$n")
    done
fi

if [[ ${#packages[@]} -eq 0 && ${#retired_pkgs[@]} -eq 0 ]]; then
    echo ""
    echo "[OK] nothing to build (all packages up to date in $REPO_DIR)"
    if [[ ${#cascade_pkgs[@]} -gt 0 ]]; then
        echo "[!] ${#cascade_pkgs[@]} pkg(s) flagged for cascade-warn above — review and PR pkgrel bumps"
    fi
    exit 0
fi

echo ""
if [[ ${#packages[@]} -gt 0 ]]; then
    echo "[*] Will build ${#packages[@]} package(s) in dep order: ${packages[*]}"
fi
if [[ ${#retired_pkgs[@]} -gt 0 ]]; then
    echo "[*] Will retire ${#retired_pkgs[@]} package(s) (no PKGBUILD in pkgs/): ${retired_pkgs[*]}"
fi
if [[ ${#cascade_pkgs[@]} -gt 0 ]]; then
    echo "[!] ${#cascade_pkgs[@]} pkg(s) flagged for cascade-warn — review and PR pkgrel bumps after this run: ${cascade_pkgs[*]}"
fi

if $DRY_RUN; then
    echo ""
    echo "[OK] --dry-run, exiting before makepkg / gpg / repo-add / repo-remove"
    exit 0
fi

echo ""
echo "[*] Warming up gpg-agent (YubiKey PIN cache)"
gpg-connect-agent "SCD SERIALNO" /bye >/dev/null
# 挿入中 YubiKey の serial で stub を再 learn (= 両 YubiKey 切替時の
# "Please insert card with serial ..." を回避)。
gpg --card-status >/dev/null 2>&1 || true

# Phase 1: 退役 pkg を db から外し、 orphan file を prune する。
# build loop / repo-add より前に走らせる必要がある (= 後段の repo-add は
# `*.pkg.tar.zst` glob を使うので、 退役 pkg の file を残したまま走らせると
# 退役したはずの pkg が db に再 add されてしまう)。
if [[ ${#retired_pkgs[@]} -gt 0 ]]; then
    echo ""
    echo "[*] Retiring ${#retired_pkgs[@]} package(s) from db: ${retired_pkgs[*]}"
    pushd "$REPO_DIR" >/dev/null
    repo-remove --sign --key "${NEKONO_GPG_FP}!" "$DB_NAME.db.tar.gz" \
        "${retired_pkgs[@]}"
    popd >/dev/null
    echo ""
    echo "[*] Pruning orphan files for retired packages"
    "$REPO_ROOT/bin/prune"
fi

# Phase 2: 新 build + repo-add + 最終 prune。 packages が空 (= retirement-only
# 実行) ならまるごと skip する。
if [[ ${#packages[@]} -gt 0 ]]; then
    for pkg in "${packages[@]}"; do
        pkg_dir="$REPO_ROOT/pkgs/$pkg"
        if [[ ! -f "$pkg_dir/PKGBUILD" ]]; then
            echo "[WARN] skip $pkg (no PKGBUILD)" >&2
            continue
        fi

        echo ""
        echo "============================================================"
        echo "[*] Building $pkg"
        echo "============================================================"

        pushd "$pkg_dir" >/dev/null

        # このビルドが実際に作る package file 名を PKGBUILD 評価だけで確定
        # (source 未取得でも pkgname/pkgver/pkgrel/arch から計算可能)。
        # `*.pkg.tar.zst` の素の glob で代用すると、 PKGBUILD の source[] が
        # 前段の release tarball としてたまたま `*.pkg.tar.zst` を使っている
        # 場合 (= sunshine-bin が upstream の prebuilt sunshine パッケージを
        # source[] に持つ) に、 SRCDEST 未設定の build host では downloaded
        # source がこの pkg dir に降ってきて glob に混ざり、 未 review の
        # upstream 生成物がそのまま [nekono] db に登録される事故になる。
        mapfile -t _expected_pkgfiles < <(makepkg --packagelist)

        # 既存の同一 package version の中間物 / sig は掃除して再現性確保
        rm -f -- "${_expected_pkgfiles[@]}" "${_expected_pkgfiles[@]/%/.sig}"

        # makepkg: deps install + tarball verify + build + package。
        # -s で deps を pacman -S、-c で build 後 src/pkg を clean。
        # --sign は makepkg が builtin GPG 署名する flag、Nekono GPG fp を指定。
        # `!` 末尾で primary key 強制固定 (= card に load されていない subkey に
        # 流れて "wrong card" になる事故防止、詳細は bin/update-repo コメント参照)。
        makepkg -sc --noconfirm --sign --key "${NEKONO_GPG_FP}!"

        # 生成物 (.pkg.tar.zst + .sig) だけを repo/x86_64/ に移動 (= 上記の
        # 期待 file 一覧のみ、 downloaded source 等の巻き込みを防ぐ)
        mv -- "${_expected_pkgfiles[@]}" "${_expected_pkgfiles[@]/%/.sig}" "$REPO_DIR/"

        popd >/dev/null
    done

    echo ""
    echo "[*] Updating $DB_NAME repo db at $REPO_DIR"
    pushd "$REPO_DIR" >/dev/null

    # nginx が serve するため world-readable に揃える。 ENOSPC 等で mv 直後の
    # artifact が 0600 のまま残った事例があり、 client が 403 で取得失敗する。
    chmod 0644 -- *.pkg.tar.zst *.pkg.tar.zst.sig

    # repo-add は同一 pkgname を複数渡されると **last-wins** (= 最後に渡された
    # version が db entry を上書きする。 version 比較 (vercmp) はしない)。 素の
    # glob 展開は lexical 順なので "<pkg>-X.Y-10" が "<pkg>-X.Y-9" より **前** に
    # 来てしまい ('1' < '9')、 旧 build が新 build を上書きする。 その後 prune が
    # db 非参照になった新 build を orphan として削除し、 新 version が repo から
    # 消える (= pkgrel 9→10 境界の事故、 voicevox-engine-cuda 0.25.2-9→10 で実発生)。
    # version 昇順 (sort -V) で並べ、 新しい version を必ず最後に渡すことで
    # last-wins を正す。 旧 version file は db 非参照になるので後段の prune が掃除。
    mapfile -t _pkgfiles < <(printf '%s\n' *.pkg.tar.zst | sort -V)

    # repo-add: 既存 db に新 pkg を追加 (or 上書き)。--sign で db 自体も
    # Nekono GPG で署名 (= /etc/pacman.conf の SigLevel = Required DatabaseRequired
    # を満たす)。
    repo-add --sign --key "${NEKONO_GPG_FP}!" "$DB_NAME.db.tar.gz" \
        "${_pkgfiles[@]}"

    popd >/dev/null

    echo ""
    echo "[*] Pruning orphan packages from $REPO_DIR"
    "$REPO_ROOT/bin/prune"
fi

echo ""
echo "[OK] build-all completed. $(ls -1 "$REPO_DIR"/*.pkg.tar.zst 2>/dev/null | wc -l) signed packages in $REPO_DIR"

if [[ ${#cascade_pkgs[@]} -gt 0 ]]; then
    echo ""
    echo "[!] REMINDER: ${#cascade_pkgs[@]} pkg(s) need pkgrel bump PR (cascade-warn above): ${cascade_pkgs[*]}"
fi
