post_install() {
    echo ""
    echo "==> debuyoko-seiyuu-dicterm installed."
    echo "    Dictionary file: /usr/share/debuyoko-seiyuu-dicterm/debuyoko-seiyuu-dicterm.txt"
    echo "    To import into Mozc, run as your desktop user:"
    echo "      debuyoko-seiyuu-mozc-import"
    echo "    (Ansible will run this automatically on next site.yml run.)"
    echo ""
}

post_upgrade() {
    post_install
}
