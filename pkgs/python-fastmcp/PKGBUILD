# Maintainer: Nekono Nana KAKKO KARI <3267314+nananek@users.noreply.github.com>
# Upstream AUR Maintainer: Rafael Dominiquini <rafaeldominiquini at gmail dot com>
#
# AUR python-fastmcp の純 fork (= 機能変化なし、 改変は Maintainer 行 +
# nekono 説明コメントのみ)。 AUR 元 PKGBUILD は既に check() / checkdepends
# が空で minimal なので、 [nekono] convention の追加削除は不要。
#
# nekono-pipewire-mcp / nekono-voicevox-mcp の直接依存。 fastmcp chain の頂点。
#
# 3.3.0 以降の package 構成変更:
#   fastmcp PyPI pkg が空の meta-package に。 実コードは fastmcp-slim に分離。
#   source[] に fastmcp-slim sdist (= 実コード) と fastmcp meta sdist (= LICENSE 取得用)
#   の両方を vendor する。 build() / package() は fastmcp_slim-* dir を使う。

_upstreamver='3.4.4'
_upstreamver_regex='^[0-9]+\.[0-9]+\.[0-9]+$'
_source_type='pypi-releases'
# 3.3.0 以降: fastmcp は空 meta-pkg。 実コードは fastmcp-slim (PyPI 別 pkg)。
_slim_pkg='fastmcp-slim'
_meta_pkg='fastmcp'

pkgname='python-fastmcp'         # pacman 名は変えない (_slim_pkg が変わったため明示固定)
pkgver="${_upstreamver}"
pkgrel=1
pkgdesc="The fast, Pythonic way to build MCP servers and clients."
arch=('any')
url='https://github.com/PrefectHQ/fastmcp'
license=('Apache-2.0')           # upstream は 3.3 以降 Apache-2.0 (旧 MIT、 PKGBUILD 側追従)

depends=(
  'python'
  'uvicorn'                     # Arch 命名例外 (= prefix なし extra/uvicorn)
  'python-dotenv'
  'python-pydantic-settings'
  'python-pydantic'
  'python-authlib'
  'python-cryptography'
  'python-rich'
  'python-openai'
  'python-httpx'
  'python-pydantic-core'
  'python-starlette'
  'python-typing_extensions'
  'python-anyio'
  'python-pyperclip'
  'python-exceptiongroup'
  'python-openapi-pydantic'      # [nekono] PR #58
  'python-mcp'                  # [nekono] PR #60
  'python-jsonschema-path'       # [nekono] PR #54
  'python-uncalled-for'         # [nekono] PR #57
  'python-jsonref'              # [nekono] PR #68 (= jsonref>=1.1.0)
  'python-cyclopts'             # [nekono] PR #79 (= cyclopts>=4.0.0)
  'python-py-key-value-aio'     # [nekono] PR #80 (= py-key-value-aio[filetree,keyring,memory]>=0.4.4)
  'python-opentelemetry-api'    # Arch 公式 (= opentelemetry-api>=1.20.0)
  'python-packaging'            # Arch 公式 (= packaging>=24.0)
  'python-platformdirs'         # Arch 公式 (= platformdirs>=4.0.0)
  'python-yaml'                 # Arch 公式 (= pyyaml>=6.0,<7.0)
  'python-websockets'           # Arch 公式 (= websockets>=15.0.1)
  'python-watchfiles'           # Arch 公式 (= watchfiles>=1.0.0)
  'python-griffelib'            # Arch 公式 (= griffelib>=2.0.0)
  'python-multipart'            # Arch 公式 (= fastmcp-slim 3.3.x [server] extra 新規 dep)
  'python-joserfc'              # Arch 公式 (= fastmcp-slim 3.4.0 [server] extra 新規 dep、 JWT 処理を joserfc に移行)
)
makedepends=(
  'python-setuptools'
  'python-wheel'
  'python-build'
  'python-installer'
  'python-hatchling'
  'python-uv-dynamic-versioning' # [nekono] PR #59
)

source=(
    # fastmcp-slim: 実コード (3.3.0 以降の分離 pkg)
    "https://files.pythonhosted.org/packages/source/${_slim_pkg::1}/${_slim_pkg//-/_}/${_slim_pkg//-/_}-${pkgver}.tar.gz"
    # fastmcp meta-pkg sdist: LICENSE 取得のみ (slim sdist に含まれないため)
    "https://files.pythonhosted.org/packages/source/${_meta_pkg::1}/${_meta_pkg}/${_meta_pkg}-${pkgver}.tar.gz"
)
sha256sums=(
    'dcaa3e0be2127d7eacdce592c2ef0039204923dc0ec396454615cb4a3275b078'  # fastmcp_slim-3.4.4.tar.gz
    '378202e26ec15b23819d9a1c0d1b0ebda096bc712720532010a0b82a45c2b1df'  # fastmcp-3.4.4.tar.gz (meta, LICENSE用)
)


build() {
    cd "${srcdir}/fastmcp_slim-${pkgver}/"

    python -m build --wheel --no-isolation
}

package() {
    cd "${srcdir}/fastmcp_slim-${pkgver}/"

    python -m installer --destdir="$pkgdir" dist/*.whl

    # LICENSE は slim sdist に含まれないため meta-package sdist から取得
    install -Dm644 "${srcdir}/${_meta_pkg}-${pkgver}/LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"

    install -Dm644 "README.md" "${pkgdir}/usr/share/doc/${pkgname}/README.md"
    # AGENTS.md / SECURITY.md / CODE_OF_CONDUCT.md は slim sdist に含まれないため省略
}
