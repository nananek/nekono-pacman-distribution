post_install() {
    echo ""
    echo "==> okaguchi-lawyer-dicterm installed."
    echo "    Dictionary file: /usr/share/okaguchi-lawyer-dicterm/okaguchi-lawyer-dicterm.txt"
    echo "    To import into Mozc, run as your desktop user:"
    echo "      okaguchi-lawyer-mozc-import"
    echo "    (Ansible will run this automatically on next site.yml run.)"
    echo ""
}

post_upgrade() {
    post_install
}
