# Upstream AUR Maintainer: Mohamed Amine Zghal (medaminezghal) <medaminezghal at outlook dot com>
#
# AUR python-uncalled-for の純 fork (= 機能変化なし)。 nekono-pacman-distribution
# の改変:
#   - Maintainer 行を Nekono に、 AUR Maintainer は Upstream AUR として保持
#   - prepare() / check() / checkdepends を削除 (= prepare() は check() で
#     pytest-cov flag を sed する役目のみで、 check() 削除に伴い無用化)
#   - bin/build-all は --check なし default 運用、 [nekono] は AUR helper
#     前提を取らない方針
#
# python-fastmcp の transitive 依存 (fastmcp `uncalled-for>=0.2.0` 要件を満たす)。

_name=uncalled-for
pkgname=python-$_name
pkgver=0.3.2
pkgrel=1
pkgdesc="Async dependency injection for Python functions."
arch=('any')
license=('MIT')
url="https://github.com/chrisguidry/uncalled-for/"
depends=('python')
makedepends=('python-hatchling' 'python-hatch-vcs' 'python-build' 'python-installer' 'python-wheel')

source=("https://files.pythonhosted.org/packages/source/${_name::1}/$_name/${_name//-/_}-$pkgver.tar.gz")
sha256sums=('89f5dbcd71e2b8f47c030b1fa302e6cce2ec795d1ac565eeb6525c5fe55cb8a2')

build() {
    cd "$srcdir"/${_name//-/_}-$pkgver
    python -m build --wheel --no-isolation
}

package() {
    cd "$srcdir"/${_name//-/_}-$pkgver
    python -m installer --destdir="$pkgdir" dist/*.whl
}
