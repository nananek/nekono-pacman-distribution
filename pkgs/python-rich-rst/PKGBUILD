pkgname=python-rich-rst
_name=rich_rst
pkgver=2.0.1
pkgrel=1
pkgdesc="A reStructuredText renderer for rich "
arch=('any')
url="https://github.com/wasi-master/rich-rst"
license=('MIT')
depends=('python-pygments' 'python-rich')
makedepends=('python-build' 'python-installer' 'python-setuptools' 'python-wheel')
source=("https://github.com/wasi-master/rich-rst/releases/download/v$pkgver/$_name-$pkgver.tar.gz")
sha256sums=('cbe236ed0901d1ec8427cc6a50bf0a34353ba28ad014dc24def68bfe7f3b9e68')

build() {
	cd "$_name-$pkgver"
	python -m build --wheel --no-isolation
}

package() {
	cd "$_name-$pkgver"
	python -m installer --destdir="$pkgdir" dist/*.whl
}
