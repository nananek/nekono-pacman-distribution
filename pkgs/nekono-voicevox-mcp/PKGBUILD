# Maintainer: Nekono Nana KAKKO KARI <3267314+nananek@users.noreply.github.com>
#
# 自家 source PKGBUILD (= AUR fork ではない、 nananek upstream を直接 vendor)。
# claude-code から stdio で起動される MCP server (= console_script)。
# daemon ではないので systemd unit / sysusers / tmpfiles は同梱しない。
#
# fastmcp chain (PR #54〜#62 + #59 投入済み) の上に立つ MCP server。
# VOICEVOX engine HTTP API (= [nekono] voicevox-engine-cuda、 nekono-pacman0 で
# Tailscale 経由 bind) に httpx で TTS request → 戻り WAV を pw-cat で再生。

pkgname=nekono-voicevox-mcp
pkgver=0.1.0
pkgrel=1
pkgdesc="MCP server bridging VOICEVOX engine HTTP API + pw-cat for TTS playback"
arch=('any')
url="https://github.com/nananek/nekono-voicevox-mcp"
license=('MIT')
depends=(
    'python'
    'python-fastmcp'    # [nekono] PR #62
    'python-httpx'      # VOICEVOX engine HTTP API client (= Arch 公式 extra)
    'pipewire'          # pw-cat binary を subprocess.run で呼ぶ runtime 依存
)
makedepends=(
    'python-build'
    'python-installer'
    'python-wheel'
    'python-hatchling'
)
source=("$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('14a447d896a79cf97c5c8166055da946298095f6477e8cb6e19248b9ac0929af')

build() {
    cd "$pkgname-$pkgver"
    python -m build --wheel --no-isolation
}

package() {
    cd "$pkgname-$pkgver"
    python -m installer --destdir="$pkgdir" dist/*.whl
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
    install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}
