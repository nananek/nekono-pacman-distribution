# Maintainer: Nekono Nana KAKKO KARI <3267314+nananek@users.noreply.github.com>
# Upstream AUR Maintainer (voicevox-engine, CPU 版): t1ckbase
# nekono-pacman-distribution の改変 (= AUR voicevox-engine との diff):
#   - pkgname を voicevox-engine → voicevox-engine-cuda に変更し、 CUDA 専用
#     variant を表明 (provides=voicevox-engine で editor の optdepends を満たす)。
#   - source の prebuilt bundle を CPU x64 7z から NVIDIA 7z (2 part) に切替。
#     upstream 公開の sha256 が無いので makepkg --verifysource で実 DL 後に確定。
#   - build() の `pip install kanalizer pyopenjtalk` (PyPI 動的取得、 sha 検証なし)
#     を、 source[] に vendor 投入した PyPI 配布物 (sha256 pin 済み) からの
#     offline install に置換 (--no-index --no-deps)。
#   - depends に nvidia-utils を追加 (= libcuda.so.1)。 cuda / cudnn は bundle
#     に CUDA 11 + cuDNN 8 完全同梱のため敢えて入れない (Arch 公式の cuda 13 /
#     cudnn 9 と ABI mismatch + LD path 競合のリスク)。 詳細は REVIEW.md 参照。
#   - makedepends に C build tool 群を追加 (pyopenjtalk sdist が C extension build)。
#   - /usr/lib/systemd/system/voicevox-engine.service と sysusers.d, tmpfiles.d を
#     同梱 (ansible-nekonodesk の override.conf で bind IP を tailscale0 に振る運用)。
#
# 既知の divergence:
#   - upstream pyproject.toml 0.25.2 は pyopenjtalk を VOICEVOX/pyopenjtalk @
#     74703b034dd90a1f199f49bb70bf3b66b1728a86 (git fork pin) で要求しているが、
#     当 PKGBUILD は AUR と同じく PyPI の pyopenjtalk 0.4.1 を使う (AUR の動作実績
#     を踏襲)。 issue 発生時は VOICEVOX fork commit を vendoring に切替えること。
#   - upstream pyproject.toml の requires-python = "==3.11.9" を強制していない
#     (Arch system python 3.13/3.14 で AUR が動いている実績に依拠)。

pkgname=voicevox-engine-cuda
pkgver=0.25.2
pkgrel=5
pkgdesc='A http server for text-to-speech (CUDA / NVIDIA GPU build)'
arch=('x86_64')
license=('LGPL-3.0-only+nonfree')
url=https://github.com/VOICEVOX/voicevox_engine
provides=('voicevox-engine')
conflicts=('voicevox-engine')
install=$pkgname.install
# bundle 同梱の prebuilt .so 群 (= CUDA / cuDNN / onnxruntime 系) は strip 済み
# かつ debug symbol を持たないので、 makepkg の debug pkg 生成 + gdb-add-index
# 試行が大量に warning を吐く。 抑止のため !strip / !debug。
options=(!strip !debug)

# NOTE: AUR は pyworld も _syspymods に入れているが、 Arch 公式 repo に
# python-pyworld は無い (AUR のみ)。 [nekono] は AUR helper 前提を取らない
# 方針なので、 pyworld は kanalizer / pyopenjtalk と同じく source[] に PyPI
# sdist を vendor 投入してオフライン build する。
_syspymods=(fastapi importlib-metadata jaraco.text jinja markupsafe numpy platformdirs pydantic pydantic-core python-multipart semver setuptools soxr soundfile starlette yaml)

depends=(
    python
    "${_syspymods[@]/#/python-}"
    # uvicorn は Arch 命名例外で `python-` prefix が付かず `uvicorn` のまま
    # (extra/uvicorn)。 _syspymods 経由で prefix を付けると `python-uvicorn` に
    # なって不在 → 直接 list に追加する。 run.py が `import uvicorn` するため
    # 必須 (= 抜けると systemd restart loop に直結)。
    uvicorn
    # CUDA 11 + cuDNN 8 stack は bundle (linux-nvidia/lib*.so*) に完全同梱されて
    # いるので Arch の cuda (13.x) / cudnn (9.x) は不要、 むしろ install すると
    # LD path 競合のリスクあり。 systemd service 側で
    # LD_LIBRARY_PATH=/usr/lib/VOICEVOX/vv-engine を指定して bundle 経路で resolve。
    # nvidia-utils (= libcuda.so.1, driver userspace) のみ要る (= kernel driver は
    # 別 source、 host の nvidia-open or nvidia パッケージで入っている前提)。
    nvidia-utils
    python-psutil  # 0.25.2 新規 runtime dep (= core_initializer.py で psutil.cpu_count(logical=False))
)
makedepends=(
    python-build
    python-setuptools
    python-installer
    python-wheel
    python-pip
    cython
    gcc
    make
    autoconf
    automake
    7zip  # multi-volume 7z (= nvidia bundle .7z.001 + .002) は libarchive 未対応
)

# 7z 内 top-level dir。 `7z l voicevox_engine-linux-nvidia-${pkgver}.7z.001`
# で確認済み (= REVIEW.md §「NVIDIA bundle」の検証記録参照)。 AUR CPU 版は
# "linux-cpu-x64" で異なるため、 variant 切替時はこの値を要更新。
_bundle_dir=linux-nvidia

source=(
    "${url}/archive/refs/tags/${pkgver}.tar.gz"
    https://github.com/r9y9/open_jtalk/releases/download/v1.11.1/open_jtalk_dic_utf_8-1.11.tar.gz
    "${url}/releases/download/${pkgver}/voicevox_engine-linux-nvidia-${pkgver}.7z.001"
    "${url}/releases/download/${pkgver}/voicevox_engine-linux-nvidia-${pkgver}.7z.002"
    # PyPI vendor (sha256 pin):
    "https://files.pythonhosted.org/packages/a9/82/5c93ae789fa44f3615ee465e36ce39ea4c3973d597a93dfa4c8ba4ff6edf/kanalizer-0.1.1-cp39-abi3-manylinux_2_28_x86_64.whl"
    "https://files.pythonhosted.org/packages/58/74/ccd31c696f047ba381f9b11a504bf1199756c3f30f3de64e3eeb83e10b4a/pyopenjtalk-0.4.1.tar.gz"
    "https://files.pythonhosted.org/packages/a5/0f/c78d631ffbb4c1aaebf80ff2bf9e791213b381dbe404f9ce1a3eb3672931/pyworld-0.3.5.tar.gz"
    # local files:
    "voicevox-engine.service"
    "voicevox-engine.sysusers"
    "voicevox-engine.tmpfiles"
)
noextract=(
    "voicevox_engine-linux-nvidia-${pkgver}.7z.001"
    "voicevox_engine-linux-nvidia-${pkgver}.7z.002"
    "kanalizer-0.1.1-cp39-abi3-manylinux_2_28_x86_64.whl"
    "pyopenjtalk-0.4.1.tar.gz"
    "pyworld-0.3.5.tar.gz"
)
sha256sums=(
    '0fdc15638a6385509aa5ca756076531fad108bd91f61fbce40e95e634ad11595'
    'fe6ba0e43542cef98339abdffd903e062008ea170b04e7e2a35da805902f382a'
    'b7e2fb54ed6abca3f4003982e97e8496a254a8d0b93ade4a9dd6a3fcca946479'  # voicevox_engine-linux-nvidia-0.25.2.7z.001 (DL + sha256 確定済み 2026-05-21)
    '775d0c495535d44cab77ec219b80e2495a7e151f61ffda70489c4d0d96d52d04'  # voicevox_engine-linux-nvidia-0.25.2.7z.002
    'bb86f3fa2cfe4034fa68f3035e3235bb6ee314e1957aac9c0426d651e473709a'
    'd5ada46f7fc2b52c1c79c273eb9668ff6ad7ab276a8db9d8be119ef93440f0dc'
    '1b93e53cddb67a0e4faa34d6cf919ac6c662feb1c8c0ed901d71b595ab396aa3'
    '956c16b9c81d72bb5d4067c6e0ff71f55651584edb54fc307788462d4f452bd8'  # voicevox-engine.service
    '580d6feb690711adf929b8054a57b269606d03e042c2fdd7ef4ca3fc0033f119'  # voicevox-engine.sysusers
    '8eef6d4a0c5e795c49920607a627f7372c8b96fb422cff6956b516c7f2fc9fec'  # voicevox-engine.tmpfiles
)

build() {
  cd "$srcdir"
  # NVIDIA bundle (multi-volume 7z) は 7z で結合解凍。 part1 指定で同 dir の
  # part2 も自動で読まれる。 不要 file の filter は package() で mv 時に行う。
  7z x -y "voicevox_engine-linux-nvidia-${pkgver}.7z.001"

  # engine の Python wheel を source から build (= AUR 踏襲)
  cd "$srcdir/voicevox_engine-${pkgver}"
  rm -rf resources  # avoid build err. non-production assets
  python -m build --wheel --no-isolation
}

package() {
  cd "$srcdir"

  # 1) engine wheel を一時 dir に installer → site-packages を bundle dir に放り込む
  python -m installer --destdir="$srcdir/_installed" \
    "voicevox_engine-${pkgver}/dist/"*.whl

  install -d "$pkgdir"/usr/lib/VOICEVOX
  mv "${_bundle_dir}" "$pkgdir"/usr/lib/VOICEVOX/vv-engine
  mv "$srcdir/_installed"/usr/lib/python*/site-packages/* \
    -t "$pkgdir"/usr/lib/VOICEVOX/vv-engine

  # 2a) Bundle に同梱されている Python 3.11 ビルドの kanalizer / pyopenjtalk /
  #     pyworld と関連 dist-info を除去。 bundle 内の libpython3.11.so.1.0 と
  #     合わせて 3.11 で固められているが、 我々は system Python (現状 3.14) で
  #     動かすので ABI 不一致。 さらに pip install --target は既存 dir に対し
  #     "Target directory already exists" warning で skip するので、 fresh
  #     install のために事前削除が必須。 pyopenjtalk/ 配下に bundle 同梱の
  #     open_jtalk_dic_utf_8-1.11 もあるが、 これも一度消して次の手順 (4) で
  #     source[] からの fresh tarball を mv で配置する。
  rm -rf "$pkgdir"/usr/lib/VOICEVOX/vv-engine/{kanalizer,pyopenjtalk,pyworld}
  rm -rf "$pkgdir"/usr/lib/VOICEVOX/vv-engine/{kanalizer,pyopenjtalk,pyworld}-*.dist-info

  # 2a-bis) bundle 内 basic runtime のうち、 system 版 (= gcc-libs / glibc) で
  #         安全に置換できるものを削除。 LD_LIBRARY_PATH=/usr/lib/VOICEVOX/vv-engine
  #         を service unit で設定している都合上、 bundle 版が system より先に
  #         resolve される。 bundle 同梱の libstdc++.so.6 は古く CXXABI_1.3.15 を
  #         持たないため、 system Python の C extension (例: soxr_ext.abi3.so) の
  #         import で `version CXXABI_1.3.15 not found` ImportError 発生 (= 観測済み)。
  #         system の gcc-libs / glibc は ABI backward compatible なので、 bundle
  #         同梱の CUDA stack (libcudart 等) も system libstdc++ で問題なく動く。
  #         libgfortran / libquadmath / libscipy_openblas は scipy/numpy 依存で
  #         system に無い可能性があるため残す。
  rm -f "$pkgdir"/usr/lib/VOICEVOX/vv-engine/{libstdc++.so.6,libgcc_s.so.1,libmvec.so.1}

  # 2b) Vendored PyPI deps を offline install (= sha pin 済み)。
  #    --target で直接 bundle dir に書く。 --no-deps で再帰解決禁止。
  #    --no-build-isolation: PEP 517 の build isolation を切り、 makedepends の
  #    system python-setuptools / cython / python-numpy (depends 側) を直接
  #    build 環境として使う。 これが無いと pip が isolated venv に setuptools を
  #    fetch しようとして --no-index と衝突し fail する。
  python -m pip install \
    --no-index --no-deps --no-build-isolation \
    --no-compile --no-warn-script-location \
    --target "$pkgdir"/usr/lib/VOICEVOX/vv-engine \
    "$srcdir/kanalizer-0.1.1-cp39-abi3-manylinux_2_28_x86_64.whl" \
    "$srcdir/pyopenjtalk-0.4.1.tar.gz" \
    "$srcdir/pyworld-0.3.5.tar.gz"

  # 2c) PEP 610 の direct_url.json には pip install --target した source ファイル
  #     の絶対 path (= $srcdir 配下) が埋まる。 published .pkg.tar.zst に
  #     build host の path がリークするので削除 (= makepkg の
  #     "パッケージは $srcdir へのリファレンスを含んでいます" 警告対応)。
  rm -f "$pkgdir"/usr/lib/VOICEVOX/vv-engine/*.dist-info/direct_url.json

  # 3) Open JTalk dict を pyopenjtalk リソース dir 直下に配置 (= AUR と同じ位置)
  mv "$srcdir"/open_jtalk_dic_utf_8-1.11 \
    "$pkgdir"/usr/lib/VOICEVOX/vv-engine/pyopenjtalk/

  # 4) entrypoint
  sed '1c#!/usr/bin/python' "$srcdir/voicevox_engine-${pkgver}/run.py" | \
    install -Dm755 /dev/stdin "$pkgdir"/usr/lib/VOICEVOX/vv-engine/run

  # 5) systemd unit + sysusers + tmpfiles (pacman の systemd-* hook が install 時に走る)
  install -Dm644 "$srcdir/voicevox-engine.service" \
    "$pkgdir"/usr/lib/systemd/system/voicevox-engine.service
  install -Dm644 "$srcdir/voicevox-engine.sysusers" \
    "$pkgdir"/usr/lib/sysusers.d/voicevox-engine.conf
  install -Dm644 "$srcdir/voicevox-engine.tmpfiles" \
    "$pkgdir"/usr/lib/tmpfiles.d/voicevox-engine.conf
}
