# Contributor: Oleg Smirnov <oleg.smirnov@gmail.com>
# nekono-pacman-distribution の改変 (= AUR との diff):
#   - md5sums → sha256sums (md5 暗号学的破綻、Claude review 指摘)
#   - makedepends 明示 (= autotools 系、./bootstrap が要る)

pkgname=pam_pkcs11
pkgver=0.6.13
pkgrel=1
pkgdesc='PAM module allows a X.509 certificate based user login'
arch=('i686' 'x86_64')
url='https://opensc.github.io/pam_pkcs11/'
license=('LGPL-2.1-or-later')
depends=('pcsclite' 'openssl')
makedepends=('autoconf' 'automake' 'libtool' 'pkgconf')
backup=('etc/pam_pkcs11/pam_pkcs11.conf' 'etc/pam_pkcs11/subject_mapping' 'etc/pam_pkcs11/card_eventmgr.conf')
source=("https://github.com/OpenSC/${pkgname}/archive/${pkgname}-${pkgver}.tar.gz")
sha256sums=('8a853f4e6e136ceecdcffad798570e3d6af2fde08e975656b2dc931989c35aff')

build() {
    cd ${pkgname}-${pkgname}-${pkgver}
    ./bootstrap
    ./configure --prefix=/usr \
    --sysconfdir=/etc \
    --with-ldap=no \
    --without-docbook \
    --disable-static
#    --disable-debug # build is broken
  make
}

package() {
    cd ${pkgname}-${pkgname}-${pkgver}
    make DESTDIR="${pkgdir}" install

    install -d "${pkgdir}"/etc/pam_pkcs11/{cacerts,crls}
}
