# Maintainer: Nekono Nana KAKKO KARI <3267314+nananek@users.noreply.github.com>
# Contributor: redponike <proton (dot) me>
# Contributor: Carl Smedstad <carsme@archlinux.org>
# Contributor: Achmad Fathoni<fathoni.id(at)gmail.com>

pkgname=python-beartype
_pkgname=${pkgname#python-}
pkgver=0.22.9
pkgrel=8
pkgdesc="Unbearably fast near-real-time hybrid runtime-static type-checking in pure Python"
arch=('any')
url="https://github.com/beartype/beartype"
license=('MIT')
depends=('python>=3.9')
makedepends=(
  python-build
  python-hatchling
  python-installer
  python-wheel
)
checkdepends=(
  python-pytest
  python-numpy
  python-xarray
  python-click
  python-rich-click
  python-pygments
  python-typing_extensions
  # AUR PKGBUILD では明示されていないが、
  # beartype_test/a90_func/a50_external/test_poetry.py が `python -m poetry
  # install` を実行するため checkdepends に追加しないと build fail する
  # (= 2026-05-20 PR #69 直後の再 build で実測)
  python-poetry
)
source=("$pkgname-$pkgver.tar.gz::$url/archive/v$pkgver.tar.gz")
sha256sums=('ecc0518c0c9102637e711c8f46ce0ba561c3138c89aea522d4b28b84a5f47b2d')

build() {
  cd "$_pkgname-$pkgver"
  python -m build --wheel --no-isolation
}

check() {
  cd "$_pkgname-$pkgver"
  rm -rf tmp_install

  python -m installer --destdir=tmp_install dist/*.whl
  local site_packages=$(python -c "import site; print(site.getsitepackages()[0])")
  export PYTHONPATH="$PWD/tmp_install/$site_packages"
  # test_claw_fastmcp は Python 3.14 + multiprocessing のピクリング非互換で
  # PicklingError: it's not the same object が出るため除外 (beartype upstream 未修正)
  #
  # 以下の 11 件は beartype 0.22.9 の test suite が build host の numpy 2.5.0 /
  # Python 3.14.6 の typing 内部変更に追随できず fail するもの (= 配布する wheel
  # は既配布 0.22.9-7 と source 同一、 test suite 側の version 非互換のみ。
  # 2026-07-06 の 0.22.9-8 rebuild で実測。 詳細は REVIEW.md 更新履歴参照):
  #   - NumPy 2.5.0 の ScalarT dtype を beartype 0.22.9 が coerce できず
  #     BeartypeDecorHintNonpepNumpyException を投げる 8 件
  #     (test_redhint x2 / test_checkdoor x5 / test_beartype x1)
  #   - Python 3.14.6 の PEP585/PEP695 typing sign 判定変更で assert が
  #     ずれる 3 件 (test_pep585 / test_get_hint_pep_sign / test_is_hint_pep_type_typing)
  pytest --deselect beartype_test/a90_func/pep/test_pep561_static.py \
         --deselect beartype_test/a90_func/a40_claw/external/test_claw_fastmcp.py::test_claw_fastmcp \
         --deselect beartype_test/a00_unit/a60_check/a40_convert/a00_reduce/test_redhint.py::test_reduce_hint \
         --deselect beartype_test/a00_unit/a60_check/a40_convert/a00_reduce/test_redhint.py::test_reduce_hint_ignorable \
         --deselect beartype_test/a00_unit/a60_check/a90_door/test_checkdoor.py::test_door_is_bearable_warnings \
         --deselect beartype_test/a00_unit/a60_check/a90_door/test_checkdoor.py::test_door_die_if_unbearable \
         --deselect beartype_test/a00_unit/a60_check/a90_door/test_checkdoor.py::test_door_typehint_die_if_unbearable \
         --deselect beartype_test/a00_unit/a60_check/a90_door/test_checkdoor.py::test_door_is_bearable \
         --deselect beartype_test/a00_unit/a60_check/a90_door/test_checkdoor.py::test_door_typehint_is_bearable \
         --deselect beartype_test/a00_unit/a70_decor/a60_main/test_beartype.py::test_beartype \
         --deselect beartype_test/a00_unit/a20_util/hint/a00_pep/proposal/test_pep585.py::test_is_hint_pep585_builtin \
         --deselect beartype_test/a00_unit/a20_util/hint/a00_pep/test_a00_utilpepsign.py::test_get_hint_pep_sign \
         --deselect beartype_test/a00_unit/a20_util/hint/a00_pep/test_a90_utilpeptest.py::test_is_hint_pep_type_typing \
         -p asyncio
}

package() {
  cd "$_pkgname-$pkgver"
  python -m installer --destdir="$pkgdir" dist/*.whl
  install -vDm644 -t "$pkgdir/usr/share/licenses/$pkgname" LICENSE
}
